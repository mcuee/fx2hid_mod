 180          void TD_Poll(void)              // Called repeatedly while the device is idle
 181          {
 182   1              if( !(EP1INCS & 0x02) ) // Is the EP1INBUF available,
 183   1              {
 184   2      
 185   2      //              This keyboard code is unneeded
