 401          void ISR_Ures(void) interrupt 0
 402          {
 403   1         // whenever we get a USB reset, we should revert to full speed mode
 404   1         pConfigDscr = pFullSpeedConfigDscr;
 405   1         ((CONFIGDSCR xdata *) pConfigDscr)->type = CONFIG_DSCR;
