 350          BOOL DR_VendorCmnd(void)
 351          {
 352   1        BYTE tmp;
 353   1        
 354   1        switch (SETUPDAT[1])
 355   1        {
 356   2           case VR_NAKALL_ON:
 357   2              tmp = FIFORESET;
 358   2              tmp |= bmNAKALL;      
 359   2              SYNCDELAY;                    
 360   2              FIFORESET = tmp;
 361   2              break;
 362   2           case VR_NAKALL_OFF:
 363   2              tmp = FIFORESET;
 364   2              tmp &= ~bmNAKALL;      
 365   2              SYNCDELAY;                    
C51 COMPILER V7.07   FX2HID                                                                06/09/2026 21:01:47 PAGE 7   

 366   2              FIFORESET = tmp;
 367   2              break;
 368   2           default:
 369   2              return(TRUE);
 370   2        }
 371   1      
 372   1        return(FALSE);
 373   1      }
