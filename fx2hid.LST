 215   2              }
 216   1              if( !(EP1OUTCS & 0x02) )        // Is there something available in EP1OUTBUF
 217   1              {
 218   2      
 219   2      //              This keyboard code is unneeded by usbhidio
 220   2      /*
 221   2                      leds = 0xFF;    //Turn all off
 222   2                      if (EP1OUTBUF[0] & 0x02)        //Caps
 223   2                              leds &= 0xBF;
 224   2                      if (EP1OUTBUF[0] & 0x01)        //Scroll
 225   2                              leds &= 0xF7;
 226   2                      if (EP1OUTBUF[0] & 0x04)        //Num
 227   2                              leds &= 0xFE;
 228   2                      write_leds (leds);
 229   2      */
 230   2      
 231   2      // usbhidio code start
 232   2      
 233   2                      if (out_packet_count < 15)
 234   2                      {
 235   3                              BYTE i;
 236   3                              BYTE xdata *p = &temp_buf[(WORD)out_packet_count * 64];
 237   3                              for (i = 0; i < 64; i++)
 238   3                              {
 239   4                                      *p++ = EP1OUTBUF[i];
 240   4                              }
 241   3                              out_packet_count++;
C51 COMPILER V7.07   FX2HID                                                                06/09/2026 21:01:47 PAGE 5   

 242   3                              EP1OUTBC = 0; // Rearm EP1OUT to receive the next packet
 243   3                      }
 244   2                      else if (out_packet_count == 15)
 245   2                      {
 246   3                              BYTE i;
 247   3                              BYTE xdata *p = &temp_buf[15 * 64];
 248   3                              for (i = 0; i < 64; i++)
 249   3                              {
 250   4                                      *p++ = EP1OUTBUF[i];
 251   4                              }
 252   3                              out_packet_count = 16;
 253   3                              tx_packet_count = 0;
 254   3                              tx_state = 1;
 255   3                              // Note: we do NOT rearm EP1OUT here yet. We hold the buffer.
 256   3                      }
 257   2      
 258   2      // usbhidiocode end
 259   2      
 260   2              }
 261   1      
 262   1              // Transmit logic for split packets:
 263   1              if (tx_state == 1)
 264   1              {
 265   2                      if (!(EP1INCS & 0x02)) // Is EP1IN free?
 266   2                      {
 267   3                              BYTE i;
 268   3                              BYTE xdata *p = &temp_buf[(WORD)tx_packet_count * 64];
 269   3                              for (i = 0; i < 64; i++)
 270   3                              {
 271   4                                      EP1INBUF[i] = *p++;
 272   4                              }
 273   3                              EP1INBC = 64; // Arm EP1IN with 64 bytes
 274   3                              tx_packet_count++;
 275   3                              
 276   3                              if (tx_packet_count == 16)
 277   3                              {
 278   4                                      // Done transmitting the 1024-byte report, reset state and rearm EP1OUT
 279   4                                      out_packet_count = 0;
 280   4                                      tx_state = 0;
 281   4                                      EP1OUTBC = 0; // Rearm EP1OUT to accept the next report
 282   4                              }
 283   3                      }
 284   2              } 
 285   1      }
