 114          void TD_Init(void)             // Called once at startup
 115          {
 116   1         // set the CPU clock to 48MHz
 117   1         CPUCS = ((CPUCS & ~bmCLKSPD) | bmCLKSPD1) ;
C51 COMPILER V7.07   FX2HID                                                                06/09/2026 21:01:47 PAGE 3   

 118   1      
 119   1         // set the slave FIFO interface to 48MHz
 120   1         IFCONFIG |= 0x40;
 121   1      
 122   1        // Registers which require a synchronization delay, see section 15.14
 123   1        // FIFORESET        FIFOPINPOLAR
 124   1        // INPKTEND         OUTPKTEND
 125   1        // EPxBCH:L         REVCTL
 126   1        // GPIFTCB3         GPIFTCB2
 127   1        // GPIFTCB1         GPIFTCB0
 128   1        // EPxFIFOPFH:L     EPxAUTOINLENH:L
 129   1        // EPxFIFOCFG       EPxGPIFFLGSEL
 130   1        // PINFLAGSxx       EPxFIFOIRQ
 131   1        // EPxFIFOIE        GPIFIRQ
 132   1        // GPIFIE           GPIFADRH:L
 133   1        // UDMACRCH:L       EPxGPIFTRIG
 134   1        // GPIFTRIG
 135   1        
 136   1        // Note: The pre-REVE EPxGPIFTCH/L register are affected, as well...
 137   1        //      ...these have been replaced by GPIFTC[B3:B0] registers
 138   1      
 139   1        // default: all endpoints have their VALID bit set
 140   1        // default: TYPE1 = 1 and TYPE0 = 0 --> BULK  
 141   1        // default: EP2 and EP4 DIR bits are 0 (OUT direction)
 142   1        // default: EP6 and EP8 DIR bits are 1 (IN direction)
 143   1        // default: EP2, EP4, EP6, and EP8 are double buffered
 144   1      
 145   1        // we are just using the default values, yes this is not necessary...
 146   1        EP1OUTCFG = 0xA0;
 147   1        EP1INCFG = 0xA0;
 148   1        SYNCDELAY;                    // see TRM section 15.14
 149   1        EP2CFG = 0xA2;
 150   1        SYNCDELAY;                    
 151   1        EP4CFG = 0xA0;
 152   1        SYNCDELAY;                    
 153   1        EP6CFG = 0xE2;
 154   1        SYNCDELAY;                    
 155   1        EP8CFG = 0xE0;
 156   1      
 157   1        // out endpoints do not come up armed
 158   1        
 159   1        // since the defaults are double buffered we must write dummy byte counts twice
 160   1        SYNCDELAY;                    
 161   1        EP2BCL = 0x80;                // arm EP2OUT by writing byte count w/skip.
 162   1        SYNCDELAY;                    
 163   1        EP2BCL = 0x80;
 164   1        SYNCDELAY;                    
 165   1        EP4BCL = 0x80;                // arm EP4OUT by writing byte count w/skip.
 166   1        SYNCDELAY;                    
 167   1        EP4BCL = 0x80;    
 168   1      
 169   1        // enable dual autopointer feature
 170   1        AUTOPTRSETUP |= 0x01;
 171   1      
 172   1        EP1OUTBC = 0;                                 // The original code missed this one.
 173   1                                                                      // https://github.com/libusb/hidapi/pull/730#issuecomment-4479685364
 174   1      
 175   1        Rwuen = TRUE;                 // Enable remote-wakeup
 176   1      
 177   1      }
